# Required at runtime (set these in GitHub Actions secrets + Vercel env)
ANTHROPIC_API_KEY=sk-ant-...

# Comma-separated internal addresses that receive immediate crawler alerts
ALERT_EMAILS=alice@example.com,bob@example.com

# Gemini (used by gemini_search source type for grounded-search discovery)
GEMINI_API_KEY=AIzaSy...

# Cloudflare Browser Run (used by cf_browser_run source type for sites Python
# can't fetch — CF-challenged vendor docs etc.). The cfk_-prefixed token
# authenticates only via legacy X-Auth-Email + X-Auth-Key, not Bearer.
CLOUDFLARE_CRAWLER_API_KEY=cfk_...
CLOUDFLARE_ACCOUNT_ID=<32-char hex>
CLOUDFLARE_EMAIL=you@example.com

# Plan 3 additions
RESEND_API_KEY=re_...
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...
SITE_URL=https://tracker.example.com
