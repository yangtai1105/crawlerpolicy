---
import type { PillarDigest } from "../lib/pillar_digests";
import PillarTag from "./PillarTag.astro";

interface Props {
  pillar: "crawler" | "ecosystem" | "agent";
  digest: PillarDigest;
  windowDays: number;
}

const { pillar, digest, windowDays } = Astro.props;

const pillarLabels = {
  crawler: "Crawler docs",
  ecosystem: "Content ecosystem",
  agent: "Agent infrastructure",
};
---

<a href={`/pillars/${pillar}`} class={`pillar-card pillar-${pillar}`}>
  <header class="pillar-card-head">
    <PillarTag pillar={pillar} />
    <span class="window">{windowDays}-day read · {digest.event_count} event{digest.event_count !== 1 ? "s" : ""}</span>
  </header>

  <h2 class="pillar-headline">{digest.headline}</h2>

  {digest.themes && digest.themes.length > 0 && (
    <ul class="pillar-themes">
      {digest.themes.slice(0, 4).map((t) => <li>{t}</li>)}
    </ul>
  )}
</a>

<style>
  .pillar-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-top: 3px solid var(--border-strong);
    border-radius: 4px;
    padding: var(--space-4);
    color: var(--ink);
    transition: border-color 120ms, background 120ms;
  }
  .pillar-card:hover {
    background: var(--bg-hover);
    color: var(--ink);
  }
  .pillar-crawler { border-top-color: var(--pillar-crawler); }
  .pillar-ecosystem { border-top-color: var(--pillar-ecosystem); }
  .pillar-agent { border-top-color: var(--pillar-agent); }

  .pillar-card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-3);
  }
  .window {
    font-size: 0.7rem;
    color: var(--ink-muted);
    letter-spacing: 0.02em;
  }

  .pillar-headline {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: -0.005em;
    margin: 0;
  }

  .pillar-themes {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .pillar-themes li {
    font-size: 0.68rem;
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 1px 6px;
    border-radius: 3px;
    color: var(--ink-muted);
  }
</style>
