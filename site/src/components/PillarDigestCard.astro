---
import type { PillarDigest } from "../lib/pillar_digests";
import PillarTag from "./PillarTag.astro";

interface Props {
  pillar: "crawler" | "ecosystem" | "agent";
  digest: PillarDigest;
  windowDays: number;
}

const { pillar, digest, windowDays } = Astro.props;

const pillarLabels = {
  crawler: "Crawler docs",
  ecosystem: "Content ecosystem",
  agent: "Agent infrastructure",
};
---

<article class={`pillar-card pillar-${pillar}`}>
  <header class="pillar-card-head">
    <PillarTag pillar={pillar} />
    <span class="window">State of the {pillarLabels[pillar].toLowerCase()} · last {windowDays} days</span>
  </header>

  <h2 class="pillar-headline">{digest.headline}</h2>

  <p class="pillar-body">{digest.body}</p>

  {digest.themes && digest.themes.length > 0 && (
    <ul class="pillar-themes">
      {digest.themes.map((t) => <li>{t}</li>)}
    </ul>
  )}

  <footer class="pillar-card-foot">
    <a href={`/?pillar=${pillar}`} class="see-all">
      See {digest.event_count} event{digest.event_count !== 1 ? "s" : ""} →
    </a>
  </footer>
</article>

<style>
  .pillar-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-top: 3px solid var(--border-strong);
    border-radius: 4px;
    padding: var(--space-5);
    height: 100%;
  }
  .pillar-crawler { border-top-color: var(--pillar-crawler); }
  .pillar-ecosystem { border-top-color: var(--pillar-ecosystem); }
  .pillar-agent { border-top-color: var(--pillar-agent); }

  .pillar-card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-3);
  }
  .window {
    font-size: 0.72rem;
    color: var(--ink-muted);
    text-transform: lowercase;
    letter-spacing: 0.03em;
  }

  .pillar-headline {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .pillar-body {
    font-size: 0.92rem;
    color: var(--ink);
    line-height: 1.6;
    margin: 0;
  }

  .pillar-themes {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .pillar-themes li {
    font-size: 0.72rem;
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 2px 8px;
    border-radius: 3px;
    color: var(--ink-muted);
  }

  .pillar-card-foot { margin-top: auto; }
  .see-all {
    font-size: 0.82rem;
    color: var(--ink-muted);
  }
  .see-all:hover { color: var(--pillar-ecosystem); }
</style>
