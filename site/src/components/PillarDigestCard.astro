---
import type { PillarDigest } from "../lib/pillar_digests";

interface Props {
  pillar: "crawler" | "ecosystem" | "agent";
  digest: PillarDigest;
}

const { pillar, digest } = Astro.props;
const windowDays = digest.window_days;
const windowLabel =
  windowDays >= 365 ? `past year` : `${windowDays}d`;

const pillarLabels = {
  crawler: "Crawler docs",
  ecosystem: "Content ecosystem",
  agent: "Agent infrastructure",
};
---

<a href={`/pillars/${pillar}`} class={`pillar-card pillar-${pillar}`}>
  <div class="pillar-eyebrow">
    <span class="pillar-label">{pillarLabels[pillar]}</span>
    <span class="pillar-meta">
      {windowLabel} · {digest.event_count} event{digest.event_count !== 1 ? "s" : ""}
    </span>
  </div>

  <h2 class="pillar-headline">{digest.headline}</h2>

  {digest.themes && digest.themes.length > 0 && (
    <p class="pillar-themes">
      {digest.themes.slice(0, 4).join("  ·  ")}
    </p>
  )}

  <span class="pillar-cta">Read briefing →</span>
</a>

<style>
  .pillar-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-top: 3px solid var(--border-strong);
    border-radius: 4px;
    padding: var(--space-5);
    color: var(--ink);
    height: 100%;
    transition: border-color 150ms, transform 150ms;
  }
  .pillar-card:hover {
    border-color: var(--border-strong);
    transform: translateY(-2px);
    color: var(--ink);
  }
  .pillar-crawler { border-top-color: var(--pillar-crawler); }
  .pillar-ecosystem { border-top-color: var(--pillar-ecosystem); }
  .pillar-agent { border-top-color: var(--pillar-agent); }

  .pillar-eyebrow {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-3);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--border);
  }
  .pillar-label {
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--ink);
  }
  .pillar-crawler .pillar-label { color: var(--pillar-crawler); }
  .pillar-ecosystem .pillar-label { color: var(--pillar-ecosystem); }
  .pillar-agent .pillar-label { color: var(--pillar-agent); }

  .pillar-meta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink-muted);
    font-variant-numeric: tabular-nums;
  }

  /* The headline is the whole point — give it real presence. */
  .pillar-headline {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.015em;
    margin: 0;
    /* Force same height across the three cards by bounding to 4 lines */
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .pillar-themes {
    font-size: 0.82rem;
    color: var(--ink-muted);
    line-height: 1.5;
    margin: 0;
  }

  .pillar-cta {
    margin-top: auto;
    padding-top: var(--space-3);
    font-size: 0.8rem;
    color: var(--ink-muted);
    border-top: 1px dashed var(--border);
  }
  .pillar-card:hover .pillar-cta {
    color: var(--pillar-ecosystem);
  }
  .pillar-crawler:hover .pillar-cta { color: var(--pillar-crawler); }
  .pillar-agent:hover .pillar-cta { color: var(--pillar-agent); }

  @media (max-width: 900px) {
    .pillar-headline { font-size: 1.2rem; }
  }
</style>
