---
import PillarTag from "./PillarTag.astro";
import TimeAgo from "./TimeAgo.astro";
import { findSource } from "../lib/sources";

interface Props {
  slug: string;
  data: {
    title: string;
    source: string;
    pillar: "crawler" | "ecosystem" | "agent";
    detected_at: Date;
    change_kind: string;
    importance: number;
  };
  body?: string;
}
const { slug, data, body } = Astro.props;
const source = findSource(data.source);
const sourceName = source?.display_name ?? data.source;

// Extract a preview from the body (What changed section).
let preview = "";
if (body) {
  const match = body.match(/## What changed\s*\n+([^\n]+(?:\n[^\n#]+)*)/);
  if (match) preview = match[1].trim().slice(0, 220);
}
---

<article class="event-card" data-pillar={data.pillar}>
  <a href={`/events/${slug}`} class="event-link">
    <header class="event-header">
      <PillarTag pillar={data.pillar} />
      <span class="source-meta">
        {sourceName} · <TimeAgo date={data.detected_at} />
      </span>
    </header>
    <h3 class="event-title">{data.title}</h3>
    {preview && <p class="event-preview">{preview}</p>}
  </a>
</article>

<style>
  .event-card {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 4px;
    margin-bottom: var(--space-3);
    transition: border-color 120ms ease, background 120ms ease;
  }
  .event-card:hover {
    border-color: var(--border-strong);
    background: var(--bg-hover);
  }
  .event-link {
    display: block;
    padding: var(--space-4);
  }
  .event-link:hover { color: inherit; }
  .event-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }
  .source-meta {
    font-size: 0.78rem;
    color: var(--ink-muted);
  }
  .event-title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 500;
    line-height: 1.3;
    color: var(--ink);
    margin: 0 0 var(--space-2);
    letter-spacing: -0.01em;
  }
  .event-preview {
    font-size: 0.88rem;
    color: var(--ink-muted);
    margin: 0;
    line-height: 1.5;
  }
</style>
