---
import "@fontsource-variable/inter/index.css";
import "@fontsource/fraunces/400.css";
import "@fontsource/fraunces/500.css";
import "@fontsource/fraunces/600.css";
import "../styles/global.css";
import { loadHealth } from "../lib/sop";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Automated tracker for AI crawler docs, content ecosystem, and agent infrastructure." } = Astro.props;

const health = loadHealth();
const lastRun = health.last_run_at
  ? new Date(health.last_run_at).toUTCString().replace("GMT", "UTC")
  : "never";
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · AI Content Ecosystem Insights</title>
    <meta name="description" content={description} />
    <link rel="alternate" type="application/rss+xml" title="AI Content Ecosystem Insights" href="/feed.xml" />
  </head>
  <body>
    <nav class="site-nav">
      <div class="container site-nav-inner">
        <a href="/" class="brand">AI Content Ecosystem Insights</a>
        <div class="links">
          <a href="/">Feed</a>
          <a href="/reading">Reading</a>
          <a href="/sources">Sources</a>
          <a href="/about">About</a>
          <a href="/subscribe">Subscribe</a>
          <a href="/feed.xml">RSS</a>
          <button
            class="theme-toggle"
            type="button"
            onclick="
              const el = document.documentElement;
              const next = el.dataset.theme === 'dark' ? 'light' : 'dark';
              el.dataset.theme = next;
              localStorage.setItem('theme', next);
            "
          >
            Theme
          </button>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>Last check: <time>{lastRun}</time></p>
        <p>
          <em>What changed</em> and <em>Implication</em> sections are generated by Claude Sonnet 4.6 from raw diffs.
          Diffs are the authoritative record. Corrections welcome — see the <a href="/about">about page</a>.
        </p>
      </div>
    </footer>

    <script is:inline>
      // Apply saved theme before hydration to avoid flash.
      (function () {
        const saved = localStorage.getItem("theme");
        if (saved === "light" || saved === "dark") {
          document.documentElement.dataset.theme = saved;
        }
      })();
    </script>
  </body>
</html>
