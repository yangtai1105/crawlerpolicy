---
import Base from "../../layouts/Base.astro";
import { loadWeek, listWeeks, groupByTopic } from "../../lib/critical_reading";

export async function getStaticPaths() {
  return listWeeks().map((w) => ({
    params: { week: `${w.year}-W${String(w.week).padStart(2, "0")}` },
    props: { filename: w.filename },
  }));
}

const { week } = Astro.params;
const { filename } = Astro.props as { filename: string };
const digest = loadWeek(filename);
---

<Base title={digest ? `Critical reading — ${week}` : "Critical reading"}>
  <article class="container reading-page">
    <header class="reading-head">
      <p class="label">Weekly — critical analysis · archived</p>
      <h1>Critical reading · Week {digest?.iso_week} of {digest?.iso_year}</h1>
      <p class="back"><a href="/reading">← latest week</a></p>
    </header>

    {digest ? (
      (() => {
        const grouped = groupByTopic(digest.items, digest.topic_groups);
        return Array.from(grouped.entries()).map(([topic, items]) => {
          if (items.length === 0) return null;
          return (
            <section class="topic-block">
              <h2 class="topic-heading">{topic}</h2>
              <ul class="items">
                {items.map((it) => (
                  <li class="item">
                    <div class="item-head">
                      <a href={it.url} target="_blank" rel="noopener noreferrer" class="item-source">
                        {it.source_domain}
                      </a>
                      <span class="item-tag">{it.tag}</span>
                    </div>
                    <a href={it.url} target="_blank" rel="noopener noreferrer" class="item-title">
                      {it.title}
                    </a>
                    <p class="item-frame">{it.frame}</p>
                    {it.quote && <blockquote class="item-quote">"{it.quote}"</blockquote>}
                  </li>
                ))}
              </ul>
            </section>
          );
        });
      })()
    ) : (
      <p class="empty">No digest found for this week.</p>
    )}
  </article>
</Base>

<style>
  /* Same styles as index — duplicated to keep pages self-contained */
  .reading-page { max-width: 780px; padding: var(--space-6) var(--space-5); }
  .reading-head { margin-bottom: var(--space-6); padding-bottom: var(--space-5); border-bottom: 1px solid var(--border); }
  .reading-head h1 { font-size: 1.6rem; margin: var(--space-3) 0; }
  .back { font-size: 0.85rem; margin: var(--space-2) 0 0; }
  .back a { color: var(--pillar-ecosystem); }
  .topic-block { margin-bottom: var(--space-7); }
  .topic-heading { font-family: var(--font-display); font-size: 1.3rem; font-weight: 500; letter-spacing: -0.01em; margin: 0 0 var(--space-4); padding-bottom: var(--space-2); border-bottom: 2px solid var(--border); }
  .items { list-style: none; padding: 0; margin: 0; }
  .item { padding: var(--space-4) 0; border-bottom: 1px dashed var(--border); }
  .item:last-child { border-bottom: 0; }
  .item-head { display: flex; justify-content: space-between; align-items: baseline; gap: var(--space-3); margin-bottom: var(--space-2); font-size: 0.78rem; }
  .item-source { color: var(--ink-muted); font-family: var(--font-mono); }
  .item-source:hover { color: var(--pillar-ecosystem); }
  .item-tag { color: var(--pillar-agent); font-weight: 600; letter-spacing: 0.02em; }
  .item-title { display: block; font-family: var(--font-display); font-size: 1.08rem; font-weight: 500; line-height: 1.35; color: var(--ink); margin-bottom: var(--space-2); letter-spacing: -0.005em; }
  .item-title:hover { color: var(--pillar-ecosystem); }
  .item-frame { color: var(--ink-muted); font-size: 0.92rem; line-height: 1.55; margin: 0 0 var(--space-2); }
  .item-quote { border-left: 2px solid var(--border-strong); padding: var(--space-2) var(--space-3); margin: var(--space-2) 0 0; font-family: var(--font-display); font-style: italic; color: var(--ink); font-size: 0.95rem; line-height: 1.5; }
  .empty { color: var(--ink-muted); font-size: 0.95rem; }
</style>
