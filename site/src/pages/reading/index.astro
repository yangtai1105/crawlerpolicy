---
import Base from "../../layouts/Base.astro";
import { loadLatest, listWeeks, groupByTopic } from "../../lib/critical_reading";

const latest = loadLatest();
const archive = listWeeks().slice(1, 12);
---

<Base title="Critical reading">
  <article class="container reading-page">
    <header class="reading-head">
      <p class="label">Weekly — critical analysis</p>
      <h1>Critical reading</h1>
      <p class="lede">
        Independent commentary, investigative reporting, and analysis on AI crawlers,
        agents, copyright / legal movement, and the broader web-ecosystem impact of AI.
        Curated once a week by Gemini grounded search from specialist analysts and
        investigative journalism, not vendor announcements.
      </p>
    </header>

    {latest ? (
      <>
        <div class="week-meta">
          <span>Week {latest.iso_week} of {latest.iso_year}</span>
          <span>·</span>
          <span>{latest.items.length} items</span>
          <span>·</span>
          <time>Generated {new Date(latest.generated_at).toUTCString().replace("GMT", "UTC")}</time>
        </div>

        {(() => {
          const grouped = groupByTopic(latest.items, latest.topic_groups);
          return Array.from(grouped.entries()).map(([topic, items]) => {
            if (items.length === 0) return null;
            return (
              <section class="topic-block">
                <h2 class="topic-heading">{topic}</h2>
                <ul class="items">
                  {items.map((it) => (
                    <li class="item">
                      <div class="item-head">
                        <a href={it.url} target="_blank" rel="noopener noreferrer" class="item-source">
                          {it.source_domain}
                        </a>
                        <span class="item-tag">{it.tag}</span>
                      </div>
                      <a href={it.url} target="_blank" rel="noopener noreferrer" class="item-title">
                        {it.title}
                      </a>
                      <p class="item-frame">{it.frame}</p>
                      {it.quote && (
                        <blockquote class="item-quote">"{it.quote}"</blockquote>
                      )}
                    </li>
                  ))}
                </ul>
              </section>
            );
          });
        })()}
      </>
    ) : (
      <p class="empty">
        No critical reading digests yet. Run{" "}
        <code>uv run python -m pipeline.critical_reading</code> to generate this week's.
      </p>
    )}

    {archive.length > 0 && (
      <section class="archive">
        <h2>Archive</h2>
        <ul class="archive-list">
          {archive.map((w) => (
            <li>
              <a href={`/reading/${w.year}-W${String(w.week).padStart(2, "0")}`}>
                Week {w.week} · {w.year}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>
</Base>

<style>
  .reading-page { max-width: 780px; padding: var(--space-6) var(--space-5); }

  .reading-head { margin-bottom: var(--space-6); padding-bottom: var(--space-5); border-bottom: 1px solid var(--border); }
  .reading-head h1 { font-size: 2rem; margin: var(--space-3) 0; }
  .reading-head .lede { color: var(--ink-muted); font-size: 1rem; line-height: 1.7; max-width: 680px; margin: 0; }

  .week-meta {
    display: flex; gap: var(--space-2); flex-wrap: wrap;
    color: var(--ink-muted); font-size: 0.82rem; margin-bottom: var(--space-6);
    font-variant-numeric: tabular-nums;
  }

  .topic-block { margin-bottom: var(--space-7); }
  .topic-heading {
    font-family: var(--font-display);
    font-size: 1.3rem; font-weight: 500;
    letter-spacing: -0.01em;
    margin: 0 0 var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 2px solid var(--border);
  }

  .items { list-style: none; padding: 0; margin: 0; }
  .item {
    padding: var(--space-4) 0;
    border-bottom: 1px dashed var(--border);
  }
  .item:last-child { border-bottom: 0; }

  .item-head {
    display: flex; justify-content: space-between; align-items: baseline;
    gap: var(--space-3); margin-bottom: var(--space-2);
    font-size: 0.78rem;
  }
  .item-source { color: var(--ink-muted); font-family: var(--font-mono); }
  .item-source:hover { color: var(--pillar-ecosystem); }
  .item-tag {
    color: var(--pillar-agent);
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .item-title {
    display: block;
    font-family: var(--font-display);
    font-size: 1.08rem;
    font-weight: 500;
    line-height: 1.35;
    color: var(--ink);
    margin-bottom: var(--space-2);
    letter-spacing: -0.005em;
  }
  .item-title:hover { color: var(--pillar-ecosystem); }

  .item-frame {
    color: var(--ink-muted);
    font-size: 0.92rem;
    line-height: 1.55;
    margin: 0 0 var(--space-2);
  }

  .item-quote {
    border-left: 2px solid var(--border-strong);
    padding: var(--space-2) var(--space-3);
    margin: var(--space-2) 0 0;
    font-family: var(--font-display);
    font-style: italic;
    color: var(--ink);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .empty { color: var(--ink-muted); font-size: 0.95rem; }
  .empty code { background: var(--bg-elev); padding: 2px 6px; border-radius: 3px; }

  .archive { margin-top: var(--space-8); padding-top: var(--space-5); border-top: 1px solid var(--border); }
  .archive h2 { font-size: 1.1rem; margin-bottom: var(--space-3); }
  .archive-list { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .archive-list li { font-size: 0.82rem; }
  .archive-list a {
    display: inline-block;
    padding: 4px 10px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--ink-muted);
  }
  .archive-list a:hover { color: var(--ink); border-color: var(--border-strong); }
</style>
