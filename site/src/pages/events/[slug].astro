---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import PillarTag from "../../components/PillarTag.astro";
import TimeAgo from "../../components/TimeAgo.astro";
import { findSource } from "../../lib/sources";

export async function getStaticPaths() {
  const events = await getCollection("events");
  return events.map((e) => ({ params: { slug: e.id }, props: { event: e } }));
}

const { event } = Astro.props;
const { Content } = await render(event);
const source = findSource(event.data.source);
---

<Base title={event.data.title} description={`Tracked change from ${source?.display_name ?? event.data.source}`}>
  <article class="container event-page">
    <header class="event-page-header">
      <div class="event-page-meta">
        <PillarTag pillar={event.data.pillar} />
        <span class="source-name">
          {source?.display_name ?? event.data.source}
        </span>
        <span class="dot">·</span>
        <TimeAgo date={event.data.detected_at} />
      </div>
      <h1 class="event-page-title">{event.data.title}</h1>
      {event.data.source_url && (
        <p class="event-page-url">
          Source:
          <a href={event.data.source_url} target="_blank" rel="noopener noreferrer">
            {event.data.source_url}
          </a>
        </p>
      )}
    </header>

    <div class="event-page-body">
      <Content />
    </div>

    <footer class="event-page-footer">
      <p>
        What changed and Implication sections are generated by Claude Sonnet 4.6 from the raw
        diff above. The diff is the authoritative record.
      </p>
      <p>
        <a href={`/sources/${event.data.source}`}>
          See all tracked changes from {source?.display_name ?? event.data.source} →
        </a>
      </p>
    </footer>
  </article>
</Base>

<style>
  .event-page {
    max-width: 780px;
    padding: var(--space-6) var(--space-5);
  }
  .event-page-header {
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--space-6);
  }
  .event-page-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: 0.85rem;
    color: var(--ink-muted);
    margin-bottom: var(--space-3);
  }
  .source-name { color: var(--ink); }
  .dot { opacity: 0.5; }
  .event-page-title {
    font-size: 2rem;
    line-height: 1.2;
  }
  .event-page-url {
    margin-top: var(--space-3);
    font-size: 0.85rem;
    color: var(--ink-muted);
    word-break: break-all;
  }
  .event-page-url a { color: var(--pillar-ecosystem); }

  .event-page-body :global(h2) {
    font-size: 1.15rem;
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
  }
  .event-page-body :global(h2):first-of-type { margin-top: 0; }

  .event-page-body :global(details) {
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: var(--space-3) var(--space-4);
    margin-top: var(--space-5);
    background: var(--bg-elev);
  }
  .event-page-body :global(summary) {
    cursor: pointer;
    color: var(--ink-muted);
    font-size: 0.88rem;
    font-weight: 500;
  }
  .event-page-body :global(details[open]) { padding-bottom: var(--space-4); }
  .event-page-body :global(pre.astro-code),
  .event-page-body :global(pre) {
    font-size: 0.8rem;
    max-height: 500px;
  }

  .event-page-footer {
    margin-top: var(--space-8);
    padding-top: var(--space-5);
    border-top: 1px solid var(--border);
    color: var(--ink-muted);
    font-size: 0.82rem;
  }
  .event-page-footer a { color: var(--pillar-ecosystem); }
</style>
